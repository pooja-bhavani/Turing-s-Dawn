# Copy to `.env` and fill in to enable live Google Gemini hints.
# Without a key the game still runs — it falls back to authored hints.
#
# Get a key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Optional: override the model (default: gemini-2.5-flash).
# VITE_GEMINI_MODEL=gemini-2.5-flash
